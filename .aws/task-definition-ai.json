{
  "family": "simplewell-ai-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::150619449855:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::150619449855:role/simplewell-ai-task-role",
  "containerDefinitions": [
    {
      "name": "simplewell-ai",
      "image": "150619449855.dkr.ecr.ap-southeast-1.amazonaws.com/simplewell-ai-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "ai",
          "containerPort": 8000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "APP_ENV",
          "value": "production"
        },
        {
          "name": "LOG_LEVEL",
          "value": "INFO"
        },
        {
          "name": "DEEPSEEK_BASE_URL",
          "value": "https://api.deepseek.com"
        },
        {
          "name": "DEEPSEEK_CHAT_MODEL",
          "value": "deepseek-v4-flash"
        },
        {
          "name": "DEEPSEEK_ADVICE_MODEL",
          "value": "deepseek-v4-flash"
        }
      ],
      "secrets": [
        {
          "name": "DEEPSEEK_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:150619449855:secret:simplewell/prod/deepseek-api-key"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health')\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/simplewell-ai",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}